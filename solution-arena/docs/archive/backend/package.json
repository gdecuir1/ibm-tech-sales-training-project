{
  "name": "ibm-dealsprint-backend",
  "version": "1.0.0",
  "description": "Backend API for IBM DealSprint - Sales Training Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node tests/run-all-tests.js",
    "test:evaluate": "node tests/evaluate.test.js",
    "test:scoring": "node tests/scoring.test.js",
    "test:integration": "node tests/integration.test.js",
    "db:setup": "psql -d dealsprint -f ../database/schema.sql",
    "db:seed": "node ../database/seed.js",
    "db:reset": "node ../database/seed.js --clear"
  },
  "keywords": [
    "ibm",
    "dealsprint",
    "sales",
    "training",
    "simulator",
    "postgresql"
  ],
  "author": "Bob",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}