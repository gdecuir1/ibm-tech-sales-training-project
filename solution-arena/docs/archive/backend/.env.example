# IBM DealSprint Backend Environment Configuration
# Copy this file to .env and update with your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Local Development
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dealsprint
DB_USER=postgres
DB_PASSWORD=your_password_here

# Connection Pool Settings
DB_POOL_MAX=20
DB_POOL_MIN=2
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=10000

# SSL Configuration (set to true for IBM Cloud)
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# IBM Cloud Databases for PostgreSQL (Production)
# Uncomment and update these for production deployment
# DB_HOST=your-instance.databases.appdomain.cloud
# DB_PORT=32541
# DB_NAME=ibmclouddb
# DB_USER=ibm_cloud_user
# DB_PASSWORD=your_ibm_cloud_password
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment
NODE_ENV=development

# Server Port
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# JWT Secret (for authentication - generate a secure random string)
# JWT_SECRET=your_jwt_secret_here

# Session Secret
# SESSION_SECRET=your_session_secret_here

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable features
ENABLE_ANALYTICS=true
ENABLE_LEADERBOARD=true
ENABLE_ACHIEVEMENTS=true

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# IBM App ID (for authentication)
# APPID_CLIENT_ID=your_client_id
# APPID_CLIENT_SECRET=your_client_secret
# APPID_OAUTH_SERVER_URL=https://us-south.appid.cloud.ibm.com/oauth/v4/your_tenant_id

# IBM Cloud Object Storage (for backups)
# COS_ENDPOINT=s3.us-south.cloud-object-storage.appdomain.cloud
# COS_API_KEY=your_cos_api_key
# COS_INSTANCE_ID=your_cos_instance_id
# COS_BUCKET=dealsprint-backups

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit window (milliseconds)
RATE_LIMIT_WINDOW=900000

# Max requests per window
RATE_LIMIT_MAX=100

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit the actual .env file to version control
# 2. Keep production credentials secure
# 3. Use IBM Cloud Secrets Manager for production secrets
# 4. Rotate credentials regularly
# 5. Use strong, unique passwords for database access